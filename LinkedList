#include <iostream>
using namespace std;


struct Node {
    int data;
    Node* next;
};


class LinkedList {
private:
    Node* head;

public:
    
    LinkedList() {
        head = NULL;
    }

    
    void InsertAtEnd(int val) {
        Node* newNode = new Node;
        newNode->data = val;
        newNode->next = NULL;

        
        if (head == NULL) {
            head = newNode;
            return;
        }

        
        Node* temp = head;
        while (temp->next != NULL) {
            temp = temp->next;
        }

        
        temp->next = newNode;
    }

    
    void display() {
        Node* temp = head;

        while (temp != NULL) {
            cout << temp->data << " -> ";
            temp = temp->next;
        }

        cout << "NULL" << endl;
    }
};


int main() {
    LinkedList list;

    list.InsertAtEnd(10);
    list.InsertAtEnd(20);
    list.InsertAtEnd(30);

    list.display();

    return 0;
}
