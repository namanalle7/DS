
#include<iostream>
using namespace std;
int main() {
    int a[5]= {5,3,1,7,23};
    int s,i;
    int n=5;
    cout<<"Enter element to be searched:"<<endl;
    cin>>s;
    for(i=0; i<n; i++) {
        if(a[i]==s) {
            cout<<"Element found at "<<i+1<<endl;
            break;
        }
    }
    return 0;
}
