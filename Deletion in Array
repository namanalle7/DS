#include<iostream>
using namespace std;
int main() {
    int arr[10]= {10,20,30,40};
    int n=4;
    int pos,i;
    cout<<"Enter position to be deleted:";
    cin>>pos;
    cout<<"Array before deletion "<<endl;
    for(i=0; i<n; i++) {
        cout<<arr[i]<<endl;
    }
    n--;
    cout<<"Array after deletion"<<endl;
    for(i=0; i<n; i++) {
        cout<<arr[i]<<" ";
    }
    return 0;
}
