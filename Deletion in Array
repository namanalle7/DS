#include<iostream>
using namespace std;
int main(){
	int arr[10]={10, 20, 30, 40};
	int n=4;
	int pos,i;
	cout<<"Enter position to be deleted:";
	cin>>pos;
	cout<<"array before deletion"<<endl;
	for(i=0;i<n;i++){
		cout<<arr[i]<<endl;
	}
	for(i=pos-1;i<n;i++){
		arr[i]=arr[i+1];
	}
	n--;
	cout<<"array after deletion"<<endl;
	for(i=0;i<n;i++){
		cout<<arr[i]<<" ";
	}
	return 0;
}
