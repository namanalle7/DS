
#include<iostream>
using namespace std;
#define MAX 5
int stackArr[MAX];
int top=-1;


void push(int value){
	if(top==MAX-1){
		cout<<"Stack overflow: \n";
		return;
	}
	stackArr[++top]=value;
	cout<<value<<" pushed into stack\n";
}


void pop(){
	if(top==-1){
		cout<<"Stack Underflow: \n";
		return;
	}
	cout<<stackArr[top--]<<" popped from stack\n";
}


void peek(){
	if(top==-1){
	cout<<"Stack id empty\n";
	return;
}
cout <<"Top Element:"<<stackArr[top]<<endl;
}
void display(){
	if(top==-1){
	cout<<"Stack is empty\n";
	return;
}
cout<<"Stack Elements: ";
for(int i=top;i>=0;i--){
	cout<<stackArr[i]<<" ";
}
cout<<endl;
}
int main(){
	push(10);
	push(20);
	push(30);
	
	display();
	peek();
	
	pop();
	display;
	
	return 0;
}
